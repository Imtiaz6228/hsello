# ===== NEXUS Marketplace Environment Configuration =====

# Core
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
CORS_ORIGIN=
COOKIE_DOMAIN=

# Security
JWT_SECRET=change-me-to-a-32-char-minimum-secret-key
CSRF_SECRET=change-me-to-a-32-char-minimum-csrf-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexus

# Redis (Upstash or Railway)
REDIS_URL=redis://localhost:6379

# Cron
CRON_SECRET=your-cron-secret-key

# Admin
ADMIN_EMAIL=admin@nexus.market
ADMIN_PASSWORD=replace-with-a-unique-random-password
ADMIN_WALLET_ADDRESS=
ADMIN_WALLET_LABEL=main
TOPUP_TRC20_ADDRESS=
TOPUP_ERC20_ADDRESS=
TOPUP_BEP20_ADDRESS=
TOPUP_BTC_ADDRESS=
TOPUP_ETH_ADDRESS=
TOPUP_SOL_ADDRESS=

# Commissions
COMMISSION_SALE_PERCENT=10
COMMISSION_WITHDRAW_PERCENT=3
FROZEN_HOLD_HOURS=72
DOWNLOAD_LINK_EXPIRY_DAYS=7

# Blockchain Explorers
TRONGRID_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# AI / OpenAI
OPENAI_API_KEY=
DEEPL_API_KEY=

# Payments - NowPayments / Binance
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Email (Resend)
RESEND_API_KEY=

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nexus.market
ADMIN_NOTIFICATION_EMAIL=admin@nexus.market

# Upload
UPLOAD_DIR=uploads
PRIVATE_UPLOAD_DIR=private-uploads
MAX_UPLOAD_BYTES=8388608
MAX_PRODUCT_FILE_BYTES=104857600

# Crypto
CRYPTO_PAYMENT_ADDRESS=
CRYPTO_PAYMENT_ASSET=USDT
CRYPTO_PAYMENT_NETWORK=TRC20
CRYPTO_PAYMENT_TIMEOUT_MINUTES=30
CRYPTO_WEBHOOK_SECRET=
