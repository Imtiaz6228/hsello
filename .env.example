# ===== Ysello Marketplace Environment Configuration =====

# Core
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
CORS_ORIGIN=
COOKIE_DOMAIN=
# Production values:
# APP_URL=https://ysello.com
# API_URL=https://api.ysello.com
# CORS_ORIGIN=https://ysello.com,https://www.ysello.com

# Frontend canonical URL and optional webmaster verification tokens
VITE_SITE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:4000
VITE_USE_REMOTE_API=false
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=
VITE_YANDEX_SITE_VERIFICATION=
VITE_BAIDU_SITE_VERIFICATION=

# Security
JWT_SECRET=change-me-to-a-32-char-minimum-secret-key
CSRF_SECRET=change-me-to-a-32-char-minimum-csrf-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ysello

# Redis (Upstash or Railway)
REDIS_URL=redis://localhost:6379

# Marketplace wallet destinations
TOPUP_TRC20_ADDRESS=
TOPUP_ERC20_ADDRESS=
TOPUP_BEP20_ADDRESS=
TOPUP_BTC_ADDRESS=
TOPUP_ETH_ADDRESS=
TOPUP_SOL_ADDRESS=

# Commissions
COMMISSION_SALE_PERCENT=10
COMMISSION_WITHDRAW_PERCENT=3
FROZEN_HOLD_HOURS=72
DOWNLOAD_LINK_EXPIRY_DAYS=7

# Stripe
STRIPE_SECRET_KEY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# SMTP (optional; registration and sign-in work without it)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Ysello <noreply@ysello.com>
ADMIN_NOTIFICATION_EMAIL=

# Upload
UPLOAD_DIR=uploads
PRIVATE_UPLOAD_DIR=private-uploads
MAX_UPLOAD_BYTES=8388608
MAX_PRODUCT_FILE_BYTES=104857600

# Crypto
CRYPTO_PAYMENT_ADDRESS=
CRYPTO_PAYMENT_ASSET=USDT
CRYPTO_PAYMENT_NETWORK=TRC20
CRYPTO_PAYMENT_TIMEOUT_MINUTES=30
CRYPTO_WEBHOOK_SECRET=
