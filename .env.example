NODE_ENV=production
# Local override only. Railway injects PORT automatically.
PORT=4000
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Railway public URL. Use the Railway URL for APP_URL too if you only want
# the all-in-one Railway deployment.
APP_URL=https://your-app.vercel.app
API_URL=https://your-api.up.railway.app
# Comma-separated list of any additional trusted frontend origins. A trailing
# slash is accepted. Prefer exact preview URLs instead of a broad wildcard.
CORS_ORIGIN=https://your-app.vercel.app
# Leave blank when using __Host- cookies.
COOKIE_DOMAIN=

JWT_SECRET=replace_with_at_least_32_random_characters
CSRF_SECRET=replace_with_a_different_32_character_secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
SHORT_REFRESH_TOKEN_HOURS=24

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_TIMEOUT_MS=8000
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# For persistent uploads on Railway, mount a volume at /app/uploads and use
# this absolute path. Otherwise, use uploads for local development.
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=2097152
PRIVATE_UPLOAD_DIR=private-uploads
MAX_PRODUCT_FILE_BYTES=104857600

TURNSTILE_REQUIRED=false
TURNSTILE_SECRET_KEY=

# Hosted payment providers. Leave a provider blank to hide/disable it.
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Shown only after an authenticated order is created.
BANK_TRANSFER_INSTRUCTIONS="Bank: Example Bank | Account: 00000000 | Use your order number as reference"
CRYPTO_PAYMENT_ADDRESS=replace_with_your_wallet_address
CRYPTO_PAYMENT_ASSET=USDT
CRYPTO_PAYMENT_NETWORK=TRC20
CRYPTO_PAYMENT_TIMEOUT_MINUTES=30
# Optional fallback text shown on the crypto invoice. Include your exact asset/network/address.
CRYPTO_PAYMENT_INSTRUCTIONS="Send exactly the displayed amount to the invoice address before the timer expires. Use your order number as reference."
# Set this and configure your blockchain/payment detector to POST /api/commerce/crypto/webhook.
CRYPTO_WEBHOOK_SECRET=replace_with_long_random_webhook_secret

# Optional Vercel build variables. The default Vercel deployment uses
# vercel.json rewrites and same-origin /api requests, so leave these blank
# unless you intentionally want the browser to call Railway directly.
VITE_API_BASE_URL=
VITE_USE_REMOTE_API=false
VITE_TURNSTILE_SITE_KEY=
