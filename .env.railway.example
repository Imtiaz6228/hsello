# Railway Environment Variables 
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway 
REDIS_URL=redis://default:password@redis.railway.internal:6379 
NODE_ENV=production 
PORT=3000 
APP_URL=https://your-app.vercel.app 
API_URL=https://hsello-production.up.railway.app
COOKIE_DOMAIN=
JWT_SECRET=GENERATE_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
CSRF_SECRET=GENERATE_A_DIFFERENT_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
UPLOAD_DIR=/app/uploads
PRIVATE_UPLOAD_DIR=/app/private-uploads
MAX_UPLOAD_BYTES=8388608
MAX_PRODUCT_FILE_BYTES=104857600
# Attach Railway volumes at /app/uploads and /app/private-uploads so logos,
# product images, and seller delivery files survive deployments.
