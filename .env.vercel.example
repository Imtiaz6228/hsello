# Vercel Environment Variables 
APP_URL=https://your-app.vercel.app 
VITE_SITE_URL=https://your-app.vercel.app
API_URL=https://hsello-production.up.railway.app 
VITE_API_BASE_URL=https://hsello-production.up.railway.app 
VITE_USE_REMOTE_API=false

# Optional webmaster verification tokens. Leave blank until each platform
# supplies the real value; the build only emits non-empty verification tags.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=
VITE_YANDEX_SITE_VERIFICATION=
VITE_BAIDU_SITE_VERIFICATION=
