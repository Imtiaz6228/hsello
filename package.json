{
  "name": "hsello-auth-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "tsx watch src/server.ts",
    "build": "npm run build:web && npm run build:api",
    "build:railway": "npm run prisma:generate && npm run build",
    "build:web": "tsc -p tsconfig.web.json && vite build",
    "build:api": "tsc -p tsconfig.api.json",
    "preview": "vite preview",
    "start": "node dist-api/server.js",
    "start:worker": "node dist-api/server/workers/index.js",
    "seed:nexus": "tsx src/scripts/seed-nexus.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "set-role": "node dist-api/scripts/promote-admin.js",
    "promote-admin": "node dist-api/scripts/promote-admin.js",
    "seed-admin": "node dist-api/scripts/seed-admin.js",
    "test-smtp": "node dist-api/scripts/test-smtp.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
