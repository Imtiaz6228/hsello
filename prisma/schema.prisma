// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model with role-based access
model User {
  id            String   @id @default(uuid())
  clerkId       String   @unique
  email         String   @unique
  role          String   @default("BUYER")
  balance       Float    @default(0)
  supplierId    String?  @unique
  reputation    Float    @default(100)
  positiveVotes Int      @default(0)
  negativeVotes Int      @default(0)
  isBanned      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  products      Product[]
  orders        Order[]
  tickets       Ticket[]
  reviewsGiven  Review[]  @relation("ReviewGiver")
  apiKeys       ApiKey[]

  @@map("users")
}

// Category tree with self-relation for nesting
model Category {
  id          String   @id @default(uuid())
  parentId    String?
  name        String
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Self-relation for tree structure
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  
  // Products in this category
  products    Product[]

  @@map("categories")
}

// Product listing by sellers
model Product {
  id            String      @id @default(uuid())
  sellerId      String
  categoryId    String
  title         String
  description   String?
  price         Float
  formatType    String      @default("SINGLE_LINE")
  delimiter     String      @default(":")
  tags          String      @default("[]")
  isActive      Boolean     @default(true)
  requiresVideo Boolean     @default(false)
  warrantyDays  Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  seller        User        @relation(fields: [sellerId], references: [id])
  category      Category    @relation(fields: [categoryId], references: [id])
  stockItems    StockItem[]
  orderItems    OrderItem[]
  bulkPrices    BulkPrice[]

  @@map("products")
}

model BulkPrice {
  id        String  @id @default(uuid())
  productId String
  minQty    Int
  maxQty    Int
  price     Float
  
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("bulk_prices")
}

// Individual stock items (the actual credentials)
model StockItem {
  id          String   @id @default(uuid())
  productId   String
  dataContent String   // The actual credential data
  isSold      Boolean  @default(false)
  isReserved  Boolean  @default(false)
  reservedAt  DateTime?
  orderId     String?
  createdAt   DateTime @default(now())
  soldAt      DateTime?

  // Relations
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order       Order?   @relation(fields: [orderId], references: [id])

  @@unique([productId, dataContent])
  @@map("stock_items")
}

// Orders
model Order {
  id            String   @id @default(uuid())
  buyerId       String?
  buyerEmail    String
  totalPrice    Float
  paymentStatus String   @default("PENDING")
  paymentMethod String   @default("CRYPTO")
  paymentTxId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  buyer         User?      @relation(fields: [buyerId], references: [id])
  items         OrderItem[]
  stockItems    StockItem[]
  ticket        Ticket?

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// Support tickets and disputes
model Ticket {
  id          String   @id @default(uuid())
  orderId     String   @unique
  buyerId     String?
  sellerId    String?
  status      String   @default("OPEN")
  type        String   @default("SUPPORT")
  subject     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  order       Order        @relation(fields: [orderId], references: [id])
  buyer       User?        @relation(fields: [buyerId], references: [id])
  messages    TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  senderId    String?
  senderType  String   @default("BUYER")
  message     String
  attachments String?  // JSON array of file URLs
  createdAt   DateTime @default(now())

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// Reviews for seller reputation
model Review {
  id         String   @id @default(uuid())
  orderId    String
  sellerId   String
  buyerId    String
  isPositive Boolean
  comment    String?
  createdAt  DateTime @default(now())

  buyer      User     @relation("ReviewGiver", fields: [buyerId], references: [id])

  @@unique([orderId, buyerId])
  @@map("reviews")
}

// API keys for sellers
model ApiKey {
  id        String   @id @default(uuid())
  sellerId  String
  key       String   @unique
  name      String
  isActive  Boolean  @default(true)
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// Site configuration (admin settings)
model SiteConfig {
  id               String   @id @default(uuid())
  globalCommission Float    @default(10)
  minWithdrawal    Float    @default(10)
  announcement     String?
  updatedAt        DateTime @updatedAt

  @@map("site_config")
}

// Cart sessions (for stock locking)
model CartSession {
  id        String   @id @default(uuid())
  sessionId String   @unique
  items     String   // JSON array of {productId, quantity}
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("cart_sessions")
}
