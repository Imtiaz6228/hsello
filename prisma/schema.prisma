generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SELLER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum SellerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SellerDocumentType {
  ID_CARD
  PASSPORT
}

enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum ProductType {
  DOWNLOAD
  SERVICE
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  PROCESSING
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  BANK_TRANSFER
  CRYPTO
  MANUAL
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_BUYER
  AWAITING_SELLER
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum TicketCategory {
  PAYMENT_ISSUE
  DOWNLOAD_ISSUE
  REFUND_REQUEST
  PRODUCT_PROBLEM
  SELLER_ISSUE
  TECHNICAL_ISSUE
  ESCROW_DISPUTE
  DEPOSIT_ISSUE
  WITHDRAWAL_ISSUE
}

enum TopupMethod {
  CRYPTO_TRC20
  CRYPTO_ERC20
  CRYPTO_BEP20
  BTC
  ETH
  SOL
  BANK
  PAYPAL
  STRIPE
}

enum TopupStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
  EXPIRED
}

enum KbArticleStatus {
  DRAFT
  NEEDS_REVIEW
  PUBLISHED
  ARCHIVED
}

enum CommissionType {
  COMMISSION_SALE
  COMMISSION_WITHDRAW
}

enum LiveSessionStatus {
  ACTIVE
  TAKEN_OVER
  RELEASED
  ENDED
}

enum WalletTxType {
  TOPUP
  PURCHASE
  COMMISSION_SALE
  COMMISSION_WITHDRAW
  SELLER_PAYOUT
  WITHDRAWAL
  REFUND
  FROZEN_RELEASE
  ADJUSTMENT
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ReportStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}

model User {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  username        String    @unique
  email           String    @unique
  phone           String
  country         String
  city            String?
  profileImageUrl String?
  passwordHash    String
  role            Role      @default(CUSTOMER)
  isSuspended     Boolean   @default(false)
  suspensionReason String?
  suspendedAt     DateTime?
  emailVerifiedAt DateTime?
  balanceCents    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshSessions         RefreshSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sellerApplication       SellerApplication?
  reviewedApplications    SellerApplication[] @relation("SellerApplicationReviewer")
  sellerProfile           SellerProfile?
  sellerEarnings          SellerEarning[]
  withdrawalRequests      WithdrawalRequest[]
  products                Product[]            @relation("ProductSeller")
  orders                  Order[]              @relation("BuyerOrders")
  orderItems              OrderItem[]          @relation("OrderItemSeller")
  orderMessages           OrderMessage[]
  tickets                 Ticket[]             @relation("TicketCreator")
  assignedTickets         Ticket[]             @relation("TicketAssignee")
  ticketMessages          TicketMessage[]
  reviews                 Review[]
  refundRequests          Refund[]
  disputes                Dispute[]
  walletDeposits          WalletDeposit[]
  productReports          ProductReport[]
  topupRequests           TopupRequest[]
  walletTransactions      WalletTransaction[]
  liveSessions            LiveSession[]
  chatSessions            ChatSession[]
  chatMessages            ChatMessage[]

  @@index([email])
  @@index([username])
}

model RefreshSession {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  rememberMe Boolean   @default(false)
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WalletDeposit {
  id                String   @id @default(uuid())
  userId            String
  amountCents       Int
  method            String   @default("CARD")
  status            String   @default("PENDING")
  providerReference String?
  adminNotes        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SellerApplication {
  id                String                  @id @default(uuid())
  userId            String                  @unique
  userName          String
  fullLegalName     String
  phoneNumber       String
  email             String
  country           String
  stateProvince     String
  city              String
  fullAddress       String
  postalCode        String
  storeName         String
  documentName      String?
  documentType      SellerDocumentType?
  documentNumber    String?
  documentFrontPath String?
  documentFrontOriginalName String?
  documentFrontMimeType String?
  documentBackPath  String?
  documentBackOriginalName String?
  documentBackMimeType String?
  storeDescription  String
  productCategories String[]
  termsAccepted     Boolean
  status            SellerApplicationStatus @default(PENDING)
  adminNotes        String?
  reviewedAt        DateTime?
  reviewedById      String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("SellerApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model SellerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  storeName       String
  slug            String   @unique
  about           String
  logoUrl         String?
  bannerUrl       String?
  policy          String?
  isVerified      Boolean  @default(false)
  isSuspended     Boolean  @default(false)
  suspensionReason String?
  totalSales      Int      @default(0)
  averageRating   Decimal  @default(0) @db.Decimal(3, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified, isSuspended])
}

model Category {
  id              String     @id @default(uuid())
  parentId        String?
  name            String
  slug            String     @unique
  description     String
  seoTitle        String?
  seoDescription String?
  isActive        Boolean    @default(true)
  sortOrder       Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model Product {
  id                 String        @id @default(uuid())
  sellerId           String
  categoryId         String
  name               String
  slug               String        @unique
  shortDescription   String
  description        String
  type               ProductType   @default(DOWNLOAD)
  status             ProductStatus @default(PENDING)
  priceCents         Int
  priceUsdCents      Int           @default(0)
  priceCnyCents      Int           @default(0)
  priceRubCents      Int           @default(0)
  compareAtPriceCents Int?
  currency           String        @default("USD")
  coverImageUrl      String?
  deliveryNote       String?
  downloadLimit      Int           @default(5)
  downloadExpiryHours Int          @default(168)
  buyersGetUpdates   Boolean       @default(true)
  afterSalesServiceHours Int        @default(12)
  rejectionReason    String?
  averageRating      Decimal       @default(0) @db.Decimal(3, 2)
  reviewCount        Int           @default(0)
  salesCount         Int           @default(0)
  seoTitle           String?
  seoDescription     String?
  publishedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  seller    User          @relation("ProductSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  category  Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  files     ProductFile[]
  inventoryItems ProductInventoryItem[]
  orderItems OrderItem[]
  reviews   Review[]
  reports   ProductReport[]

  @@index([sellerId, status])
  @@index([categoryId, status])
  @@index([status, publishedAt])
}

model ProductFile {
  id          String   @id @default(uuid())
  productId   String
  displayName String
  storagePath String
  mimeType    String
  sizeBytes   Int
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadGrants DownloadGrant[]

  @@index([productId, isActive])
}

model ProductInventoryItem {
  id          String   @id @default(uuid())
  productId   String
  orderItemId String?
  content     String
  source      String   @default("MANUAL")
  isActive    Boolean  @default(true)
  deliveredAt DateTime?
  createdAt   DateTime @default(now())

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([productId, isActive, deliveredAt])
  @@index([orderItemId])
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  description     String?
  percentOff      Int?
  amountOffCents  Int?
  minimumCents    Int      @default(0)
  maxRedemptions  Int?
  redemptionCount Int      @default(0)
  startsAt        DateTime @default(now())
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders Order[]

  @@index([isActive, startsAt, expiresAt])
}

model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique
  invoiceNumber  String      @unique
  buyerId        String
  couponId       String?
  status         OrderStatus @default(AWAITING_PAYMENT)
  currency       String      @default("USD")
  subtotalCents  Int
  discountCents  Int         @default(0)
  totalCents     Int
  buyerEmail     String
  buyerName      String
  paidAt         DateTime?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  buyer     User          @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  coupon    Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items     OrderItem[]
  payment   Payment?
  refunds   Refund[]
  disputes  Dispute[]
  messages  OrderMessage[]
  tickets   Ticket[]

  @@index([buyerId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id             String @id @default(uuid())
  orderId        String
  productId      String
  sellerId       String
  productName    String
  quantity       Int    @default(1)
  unitPriceCents Int
  totalCents     Int

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller         User            @relation("OrderItemSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  downloadGrants DownloadGrant[]
  inventoryItems ProductInventoryItem[]
  sellerEarning  SellerEarning?
  disputes       Dispute[]
  review         Review?

  @@index([orderId])
  @@index([sellerId])
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amountCents       Int
  currency          String
  providerReference String?
  providerPayload   Json?
  failureReason     String?
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([providerReference])
}

model DownloadGrant {
  id            String    @id @default(uuid())
  orderItemId   String
  productFileId String
  tokenHash     String    @unique
  downloadCount Int       @default(0)
  maxDownloads  Int       @default(5)
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())

  orderItem   OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  productFile ProductFile    @relation(fields: [productFileId], references: [id], onDelete: Cascade)
  events      DownloadEvent[]

  @@index([orderItemId])
  @@index([expiresAt])
}

model DownloadEvent {
  id              String   @id @default(uuid())
  downloadGrantId String
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  grant DownloadGrant @relation(fields: [downloadGrantId], references: [id], onDelete: Cascade)

  @@index([downloadGrantId, createdAt])
}

model Refund {
  id             String       @id @default(uuid())
  orderId        String
  requestedById  String
  amountCents    Int
  reason         String
  status         RefundStatus @default(REQUESTED)
  adminNotes     String?
  providerReference String?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedBy User  @relation(fields: [requestedById], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([orderId])
}

model Dispute {
  id          String        @id @default(uuid())
  orderId     String
  orderItemId String?
  openedById  String
  subject     String
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  refundDemanded Boolean    @default(false)
  awaitingParty String?
  autoCloseAt DateTime?
  closedInFavorOf String?
  lastBuyerMessageAt DateTime?
  lastSellerMessageAt DateTime?
  lastAdminMessageAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  openedBy User  @relation(fields: [openedById], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([orderId])
  @@index([orderItemId])
  @@index([autoCloseAt])
}

model OrderMessage {
  id        String   @id @default(uuid())
  orderId   String
  authorId  String
  body      String
  attachmentUrl String?
  attachmentName String?
  attachmentMimeType String?
  createdAt DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model Ticket {
  id           String         @id @default(uuid())
  ticketNumber String         @unique
  creatorId    String
  assigneeId   String?
  orderId      String?
  category     TicketCategory
  status       TicketStatus   @default(OPEN)
  subject      String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  creator  User            @relation("TicketCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  assignee User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  order    Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages TicketMessage[]

  @@index([creatorId, createdAt])
  @@index([status, updatedAt])
  @@index([orderId])
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  body      String
  isInternal Boolean @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
}

model Review {
  id             String   @id @default(uuid())
  productId      String
  buyerId        String
  orderItemId    String   @unique
  rating         Int
  body           String
  mediaUrls      String[]
  isVisible      Boolean  @default(true)
  moderationNote String?
  sellerResponse String?
  respondedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer     User      @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([productId, isVisible, createdAt])
  @@index([buyerId])
}

model ProductReport {
  id         String       @id @default(uuid())
  productId  String
  reporterId String
  reason     String
  details    String?
  status     ReportStatus @default(OPEN)
  adminNotes String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([productId])
}

model SellerEarning {
  id             String   @id @default(uuid())
  sellerId       String
  orderItemId    String   @unique
  grossCents     Int
  platformFeeCents Int    @default(0)
  netCents       Int
  status         String   @default("FROZEN")
  availableAt    DateTime
  releasedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  seller    User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([sellerId, status])
  @@index([availableAt, status])
}

model WithdrawalRequest {
  id             String   @id @default(uuid())
  userId         String
  amountCents    Int
  blockchain     String
  walletAddress  String
  status         String   @default("PENDING")
  providerReference String?
  adminNotes     String?
  processedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model HomepageSection {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String
  subtitle  String?
  body      String?
  imageUrl  String?
  ctaLabel  String?
  ctaUrl    String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([isVisible, sortOrder])
}

model PublicUpload {
  id        String   @id @default(uuid())
  fileName  String   @unique
  mimeType  String
  sizeBytes Int
  data      Bytes
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ===== NEXUS Marketplace models =====

model TopupRequest {
  id              String      @id @default(uuid())
  userId          String
  amountCents     Int
  method          TopupMethod
  status          TopupStatus @default(PENDING)
  depositAddress  String
  reference       String      @unique
  txHash          String?     @unique
  screenshotPath  String?
  screenshotUrl   String?
  networkVerified Boolean     @default(false)
  adminNotes      String?
  approvedById    String?
  approvedAt      DateTime?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([reference])
}

model WalletTransaction {
  id             String        @id @default(uuid())
  userId         String
  type           WalletTxType
  amountCents    Int
  description    String
  reference      String?
  orderId        String?
  relatedId      String?
  idempotencyKey String?        @unique
  balanceAfter   Int           @default(0)
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model KbArticle {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  category    String
  content     String
  excerpt     String?
  tags        String[]
  status      KbArticleStatus @default(DRAFT)
  viewCount   Int             @default(0)
  helpfulCount Int            @default(0)
  unhelpfulCount Int          @default(0)
  createdBy    String?
  updatedBy    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status, category])
  @@index([slug])
}

model LiveSession {
  id           String             @id @default(uuid())
  userId       String
  status       LiveSessionStatus  @default(ACTIVE)
  currentUrl   String?
  country      String?
  city         String?
  ipAddress    String?
  userAgent    String?
  isTyping     Boolean            @default(false)
  screenSharing Boolean           @default(false)
  takenOverBy  String?
  lastActivity DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  events LiveSessionEvent[]

  @@index([status, lastActivity])
  @@index([userId])
}

model LiveSessionEvent {
  id        String   @id @default(uuid())
  sessionId String
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ChatSession {
  id          String   @id @default(uuid())
  userId      String
  status      String   @default("AI")
  subject     String?
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, createdAt])
  @@index([status])
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  authorId  String?
  role      String   @default("user")
  body      String
  metadata  Json?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  author  User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
}

model AdminWallet {
  id              String        @id @default(uuid())
  label           String        @unique
  address         String
  blockchain      String        @default("TRC20")
  balanceCents    Int           @default(0)
  totalReceivedCents Int        @default(0)
  totalSentCents  Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AdminTransaction {
  id             String         @id @default(uuid())
  type           CommissionType
  amountCents    Int
  description    String
  reference      String?
  orderId        String?
  withdrawalId   String?
  walletId       String?
  createdAt      DateTime       @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
}
