NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://auth_app:change_this_password@localhost:5432/auth_app?schema=public

APP_URL=https://your-app.vercel.app
API_URL=https://your-api.up.railway.app
# Comma-separated. A trailing slash is accepted. Explicit wildcard preview
# domains are supported, e.g. https://*.your-team.vercel.app
CORS_ORIGIN=https://your-app.vercel.app
# Leave blank when using __Host- cookies.
COOKIE_DOMAIN=

JWT_SECRET=replace_with_at_least_32_random_characters
CSRF_SECRET=replace_with_a_different_32_character_secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30
SHORT_REFRESH_TOKEN_HOURS=24

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="Auth App <no-reply@example.com>"
ADMIN_NOTIFICATION_EMAIL=admin@example.com

UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=2097152

TURNSTILE_REQUIRED=false
TURNSTILE_SECRET_KEY=
