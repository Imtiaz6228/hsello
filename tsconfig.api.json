{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src",
    "outDir": "dist-api",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "incremental": false
  },
  "include": [
    "src/server.ts",
    "src/api-app.ts",
    "src/config/**/*.ts",
    "src/lib/**/*.ts",
    "src/middleware/**/*.ts",
    "src/routes/**/*.ts",
    "src/schemas/**/*.ts",
    "src/services/**/*.ts",
    "src/scripts/**/*.ts"
  ]
}
