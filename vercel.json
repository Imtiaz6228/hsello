{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/uploads/(.*)", "destination": "/uploads/$1" },
    { "source": "/((?!api/|uploads/).*)", "destination": "/index.html" }
  ]
}