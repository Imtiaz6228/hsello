{
  "name": "ysello-marketplace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "dev:web": "vite",
    "dev:api": "tsx watch src/server.ts",
    "build": "npm run prisma:generate && npm run build:web && npm run build:api",
    "build:railway": "npm run build",
    "build:web": "node node_modules/typescript/bin/tsc -p tsconfig.web.json && node node_modules/vite/bin/vite.js build && node --import tsx scripts/prerender-static.mjs && node scripts/build-sites.mjs",
    "build:api": "node scripts/clean-api-build.mjs && node node_modules/typescript/bin/tsc -p tsconfig.api.json",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "start": "node dist-api/server.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:recover": "node scripts/recover-failed-migration.mjs",
    "prisma:migrate:dev": "prisma migrate dev",
    "set-role": "node dist-api/scripts/promote-admin.js",
    "promote-admin": "node dist-api/scripts/promote-admin.js",
    "test": "node --import tsx --test tests/*.test.mjs tests/*.test.ts",
    "lint": "eslint src scripts tests",
    "format:check": "prettier --check src scripts tests *.json *.mjs *.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.1"
  }
}
